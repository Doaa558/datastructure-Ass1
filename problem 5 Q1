#include <iostream>
#include <stack>
#include <string>
using namespace std;

class calculator {
public:
    int evaluate(const string& expression) {
        stack<int> st;

        int currentresult = 0;
        int currentnumber = 0;
        int currentsign = 1;

        for (char ch : expression) {

            if (isdigit(ch)) {
                currentnumber = currentnumber * 10 + (ch - '0');
            }

            else if (ch == '+') {
                apply(currentresult, currentnumber, currentsign);
                currentsign = 1;
            }

            else if (ch == '-') {
                apply(currentresult, currentnumber, currentsign);
                currentsign = -1;
            }

            else if (ch == '(') {
                st.push(currentresult);
                st.push(currentsign);

                currentresult = 0;
                currentsign = 1;
            }

            else if (ch == ')') {
                apply(currentresult, currentnumber, currentsign);

                int prevsign = st.top(); st.pop();
                int prevresult = st.top(); st.pop();

                currentresult = prevresult + prevsign * currentresult;
            }
        }

        apply(currentresult, currentnumber, currentsign);
        return currentresult;
    }

private:
    void apply(int& currentresult, int& currentnumber, int currentsign) {
        currentresult += currentsign * currentnumber;
        currentnumber = 0;
    }
};

int main() {
    calculator calc;
    string input;

    cout << "enter expression: ";
    getline(cin, input);

    cout << "result = " << calc.evaluate(input) << endl;

    return 0;
}
